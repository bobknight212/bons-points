{
  "askcliResourcesVersion": "2020-03-31",
  "profiles": {
    "default": {
      "skillMetadata": {
        "src": "./skill-package"
      },
      "code": {
        "default": {
          "src": "./lambda"
        }
      },
      "skillInfrastructure": {
        "type": "@ask-cli/cfn-deployer",
        "userConfig": {
          "templatePath": "./infrastructure/cfn-deployer/skill-stack.yaml",
          "cfnRegion": "eu-west-1",
          "runtime": "nodejs18.x",
          "handler": "index.handler",
          "cfn": {
            "capabilities": [
              "CAPABILITY_AUTO_EXPAND"
            ]
          }
        }
      }
    }
  }
}